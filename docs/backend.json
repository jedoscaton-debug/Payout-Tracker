
{
  "entities": {
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an individual employee within the system.",
      "properties": {
        "id": { "type": "string", "description": "Unique Access Key (UID) for the employee." },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["Driver", "Helper"] },
        "defaultDailyRate": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "authUid": { "type": "string" },
        "driverPayoutPercentage": { "type": "number", "description": "Individual share when acting as a Driver." },
        "helperPayoutPercentage": { "type": "number", "description": "Individual share when acting as a Helper." }
      },
      "required": ["id", "fullName", "role"]
    },
    "DeductionRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DeductionRecord",
      "type": "object",
      "description": "Admin configuration for an employee deduction claim.",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "deductionName": { "type": "string" },
        "type": { "type": "string", "enum": ["Fixed", "Installment", "One-Time", "Auto System Fee"] },
        "totalClaimAmount": { "type": "number" },
        "installmentCount": { "type": "number" },
        "installmentsPaid": { "type": "number" },
        "remainingBalance": { "type": "number" },
        "perPayrollAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Completed", "Paused", "Cancelled"] },
        "autoApply": { "type": "boolean" },
        "isSystemDefault": { "type": "boolean" },
        "lastAppliedPayDate": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["id", "employeeId", "deductionName", "type", "status"]
    },
    "PayrollItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PayrollItem",
      "type": "object",
      "description": "Employee paystub details for a specific payroll run.",
      "properties": {
        "id": { "type": "string" },
        "payrollRunId": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeNameSnapshot": { "type": "string" },
        "dailyRateSnapshot": { "type": "string" },
        "notes": { "type": "string" },
        "earningsLines": { "type": "array", "items": { "type": "string" } },
        "otherEarningsLines": { "type": "array", "items": { "type": "string" } },
        "deductionsLines": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "payrollRunId", "employeeId"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": { "$ref": "#/backend/entities/Employee" },
          "description": "Stores staff profile data."
        }
      },
      {
        "path": "/deductions/{deductionId}",
        "definition": {
          "entityName": "DeductionRecord",
          "schema": { "$ref": "#/backend/entities/DeductionRecord" },
          "description": "Stores admin-managed deduction rules."
        }
      },
      {
        "path": "/payrollRuns/{runId}/payrollItems/{itemId}",
        "definition": {
          "entityName": "PayrollItem",
          "schema": { "$ref": "#/backend/entities/PayrollItem" },
          "description": "Detailed paystub records."
        }
      }
    ]
  }
}
