
{
  "entities": {
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an individual employee within the system.",
      "properties": {
        "id": { "type": "string", "description": "Unique Access Key (UID) for the employee." },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["Driver", "Helper"] },
        "email": { "type": "string", "format": "email" },
        "contactNumber": { "type": "string" },
        "defaultDailyRate": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "authUid": { "type": "string", "description": "Firebase Auth UID, linked after first login." }
      },
      "required": ["id", "fullName", "role", "email"]
    },
    "PayrollItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PayrollItem",
      "type": "object",
      "description": "Employee paystub details for a specific payroll run.",
      "properties": {
        "id": { "type": "string" },
        "payrollRunId": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeEmailSnapshot": { "type": "string", "description": "Snapshot of employee email for security filtering." },
        "employeeNameSnapshot": { "type": "string" },
        "dailyRateSnapshot": { "type": "string" },
        "notes": { "type": "string" },
        "earningsLines": { "type": "array", "items": { "type": "string" } },
        "otherEarningsLines": { "type": "array", "items": { "type": "string" } },
        "deductionsLines": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "payrollRunId", "employeeId", "employeeEmailSnapshot"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": { "$ref": "#/backend/entities/Employee" },
          "description": "Stores HR records and Access Keys."
        }
      },
      {
        "path": "/payrollRuns/{runId}/payrollItems/{itemId}",
        "definition": {
          "entityName": "PayrollItem",
          "schema": { "$ref": "#/backend/entities/PayrollItem" },
          "description": "Detailed paystub records."
        }
      }
    ]
  }
}
