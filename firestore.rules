
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /system_users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /payrollRuns/{payrollRunId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      match /payrollItems/{payrollItemId} {
        allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
        allow write: if isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == adminId;
      allow write: if isAdmin();
    }
  }
}
