rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if the user is an administrator
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Helper to check if the user is the owner of a specific employee record
    function isOwner(employeeId) {
      return request.auth != null && request.auth.uid == employeeId;
    }

    match /employees/{employeeId} {
      allow read: if isAdmin() || isOwner(employeeId);
      allow write: if isAdmin();
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      allow read, write: if isAdmin();
    }

    match /payrollRuns/{payrollRunId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      
      match /payrollItems/{payrollItemId} {
        // Employees can read their own items if their UID matches the employeeId field
        allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
        allow write: if isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      allow write: if false; // Only manageable via Firebase Console or Admin SDK
    }
  }
}