
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Optimized admin check
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // GLOBAL RULES FOR COLLECTION GROUP QUERIES
    // This requires the query to filter by authUid to satisfy query-side validation
    match /{path=**}/payrollItems/{payrollItemId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.authUid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Allow checking system bootstrap state
    match /roles_admin/first_admin_placeholder {
      allow read: if true;
    }

    // Identity Mapping rules
    match /system_users/{userId} {
      // Allow authenticated lookup for identity resolution via query (list)
      allow read: if request.auth != null;
      
      // Allow Master Admin bootstrap and users to manage their own mapping
      allow write: if isAdmin() || 
                    (request.auth != null && (
                      (userId == 'STUDIO-MASTER-2026' && request.auth.token.email == 'masteradmin@system.oriented') ||
                      (request.auth.uid == request.resource.data.authUid) ||
                      (request.auth.uid == resource.data.authUid)
                    ));
    }

    match /employees/{employeeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /payrollRuns/{payrollRunId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      match /payrollItems/{payrollItemId} {
        // Redundant but safe document-path access
        allow read: if request.auth != null && (isAdmin() || resource.data.authUid == request.auth.uid);
        allow write: if isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      // Allow bootstrapping if no admins exist
      allow create: if request.auth != null && (!exists(/databases/$(database)/documents/roles_admin/first_admin_placeholder));
      allow write: if isAdmin();
    }
  }
}
