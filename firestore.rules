
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Case-insensitive email ownership check.
     * Ensures employees can only access records matching their verified email.
     */
    function isEmployee(email) {
      return request.auth != null && 
             request.auth.token.email.lower() == email.lower();
    }

    // Collection Group Rule for Payroll Items - supports global history search for employees
    match /{path=**}/payrollItems/{payrollItemId} {
      allow read: if request.auth != null && (
        isAdmin() || 
        isEmployee(resource.data.employeeEmailSnapshot)
      );
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if request.auth != null && (
        isAdmin() || 
        isEmployee(resource.data.email) ||
        (request.auth.uid == resource.data.authUid) ||
        (request.auth.uid == employeeId)
      );
      allow write: if isAdmin();
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /payrollRuns/{payrollRunId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      // Allow bootstrap if no admin exists
      allow create: if request.auth != null && !exists(/databases/$(database)/documents/roles_admin/first_admin_placeholder);
      allow write: if isAdmin();
    }
    
    match /roles_admin/first_admin_placeholder {
      allow read: if true;
    }
  }
}
