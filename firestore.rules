rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PROTOTYPE RULES:
     * These rules allow read and write access to all core collections for development.
     * In a production environment, these should be restricted to authenticated owners or admins.
     */

    match /employees/{employeeId} {
      allow read, write: if true;
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      allow read, write: if true;
    }

    match /payrollRuns/{payrollRunId} {
      allow read, write: if true;
      
      match /payrollItems/{payrollItemId} {
        allow read, write: if true;
      }
    }

    match /roles_admin/{adminId} {
      allow read: if true;
      allow write: if false;
    }
  }
}