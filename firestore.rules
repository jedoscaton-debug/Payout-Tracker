rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.role == "admin" ||
        request.auth.token.email.lower() == "admin@systemoriented.com" ||
        request.auth.token.email.lower() == "jedocaton1997@gmail.com"
      );
    }

    /**
     * Case-insensitive email ownership check.
     */
    function isEmployee(email) {
      return request.auth != null && 
             request.auth.token.email.lower() == email.lower();
    }

    // Collection Group Rule for Payroll Items
    match /{path=**}/payrollItems/{payrollItemId} {
      allow list: if request.auth != null && (
        isAdmin() || 
        isEmployee(resource.data.employeeEmailSnapshot)
      );
      allow get: if request.auth != null && (
        isAdmin() || 
        isEmployee(resource.data.employeeEmailSnapshot)
      );
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      // Allow list for identity handshake (searching by email)
      allow list: if request.auth != null;
      allow get: if request.auth != null && (
        isAdmin() || 
        isEmployee(resource.data.email) ||
        (request.auth.uid == resource.data.authUid) ||
        (request.auth.uid == employeeId)
      );
      allow write: if isAdmin();
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      allow list: if request.auth != null;
      allow get: if request.auth != null && (
        isAdmin() || 
        isEmployee(resource.data.driver) ||
        isEmployee(resource.data.helper)
      );
      allow write: if isAdmin();
    }

    match /payrollRuns/{payrollRunId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}