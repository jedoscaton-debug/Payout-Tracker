
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.role == "admin" ||
        request.auth.token.email.lower() == "admin@systemoriented.com" ||
        request.auth.token.email.lower() == "jedocaton1997@gmail.com" ||
        request.auth.token.email.lower() == "masteradmin@system.oriented"
      );
    }

    // Default deny for non-admins
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Allow checking bootstrap status if unauthenticated (only for initialization)
    match /roles_admin/first_admin_placeholder {
      allow read: if true;
    }
  }
}
