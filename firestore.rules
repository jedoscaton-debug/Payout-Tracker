
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the current user has an administrative role
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // Check if the current user is the owner of the system UID
    function isOwner(systemUid) {
      let userPath = /databases/$(database)/documents/system_users/$(systemUid);
      return request.auth != null && exists(userPath) && get(userPath).data.authUid == request.auth.uid;
    }

    // GLOBAL RULES FOR COLLECTION GROUP QUERIES
    // This allows employees to query their payroll items across all runs
    match /{path=**}/payrollItems/{payrollItemId} {
      allow read: if isAdmin() || (request.auth != null && isOwner(resource.data.employeeId));
    }

    // Allow anyone to check if the system is fresh (uninitialized)
    match /roles_admin/first_admin_placeholder {
      allow read: if true;
    }

    // Access mapping for System UIDs
    match /system_users/{userId} {
      allow read: if true;
      
      // Allow Master Admin bootstrap and users to manage their own mapping
      allow write: if isAdmin() || 
                    (request.auth != null && (
                      (userId == 'STUDIO-MASTER-2026' && request.auth.token.email == 'masteradmin@system.oriented') ||
                      (request.auth.uid == request.resource.data.authUid) ||
                      (request.auth.uid == resource.data.authUid)
                    ));
    }

    match /employees/{employeeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /payrollRuns/{payrollRunId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      match /payrollItems/{payrollItemId} {
        // Redundant with group rule but kept for standard document-path access
        allow read: if isAdmin() || (request.auth != null && isOwner(resource.data.employeeId));
        allow write: if isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      // Allow bootstrapping if no admins exist
      allow create: if request.auth != null && (!exists(/databases/$(database)/documents/roles_admin/first_admin_placeholder));
      allow write: if isAdmin();
    }
  }
}
