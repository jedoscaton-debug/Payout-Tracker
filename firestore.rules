
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isMaster() {
      let adminDoc = get(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
      return request.auth != null && adminDoc != null && adminDoc.data.role == 'master';
    }

    // Allow anyone to check if the system is fresh (uninitialized)
    match /roles_admin/first_admin_placeholder {
      allow read: if true;
    }

    // Allow public verification of Access Keys (System UIDs)
    match /system_users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      // Allow Master Admin to self-register/update their own node even during bootstrap
      allow write: if isAdmin() || (userId == 'STUDIO-MASTER-2026' && request.auth != null && request.auth.token.email == 'masteradmin@system.oriented');
    }

    match /employees/{employeeId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /payrollRuns/{payrollRunId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      match /payrollItems/{payrollItemId} {
        allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
        allow write: if isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      // Allow bootstrapping if no admins exist
      allow create: if request.auth != null && (!exists(/databases/$(database)/documents/roles_admin/first_admin_placeholder));
      // Standard admins can be managed by Master or Standard, but Master is protected
      allow write: if isAdmin();
    }
  }
}
