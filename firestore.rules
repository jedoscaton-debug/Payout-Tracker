rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if the user is an administrator
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /employees/{employeeId} {
      // Allow all authenticated users to read the directory to prevent race conditions during bootstrap
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /routeTrackerRows/{routeTrackerRowId} {
      // Allow all authenticated users to read logs for auditing visibility
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /payrollRuns/{payrollRunId} {
      // Allow all authenticated users to read runs metadata
      allow read: if request.auth != null;
      allow write: if isAdmin();
      
      match /payrollItems/{payrollItemId} {
        // Employees can read their own items if their UID matches the employeeId field
        allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
        allow write: if isAdmin();
      }
    }

    match /roles_admin/{adminId} {
      allow read: if request.auth != null;
      // Allow users to bootstrap themselves as administrators for prototype development
      allow write: if request.auth != null && request.auth.uid == adminId;
    }
  }
}